rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function classExists(classId) {
      return exists(/databases/$(database)/documents/classes/$(classId));
    }

    function isClassTeacher(classId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    function validNumber(val, min, max) {
      return val is number && val >= min && val <= max;
    }

    function createdAtValid() {
      return request.resource.data.createdAt is number
        && request.resource.data.createdAt > 0;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 255
        && request.resource.data.role in ['admin', 'teacher', 'student']
        && request.resource.data.createdAt is number;
      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 100);
      allow delete: if isAdmin();
    }

    match /terms/{termId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        && request.resource.data.code is string
        && request.resource.data.code.size() <= 20
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 100
        && request.resource.data.gradeLevel is string
        && request.resource.data.gradeLevel.size() <= 10
        && request.resource.data.teacherId is string
        && request.resource.data.termId is string
        && request.resource.data.gradingComponents is list
        && request.resource.data.createdAt is number;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if (isTeacher() || isAdmin())
        && request.resource.data.subjectId is string
        && request.resource.data.section is string
        && request.resource.data.section.size() <= 50
        && request.resource.data.teacherId is string
        && request.resource.data.schedule is string
        && request.resource.data.schedule.size() <= 100
        && request.resource.data.room is string
        && request.resource.data.room.size() <= 50
        && request.resource.data.termId is string
        && createdAtValid();
      allow update: if (isTeacher() && isClassTeacher(classId))
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId)
          && request.resource.data.studentId is string
          && request.resource.data.componentId is string
          && validNumber(request.resource.data.score, 0, 100)
          && validNumber(request.resource.data.maxScore, 1, 100));
      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId));
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId)
          && request.resource.data.studentId is string
          && request.resource.data.date is string
          && request.resource.data.date.size() <= 12
          && request.resource.data.status in ['PRESENT', 'ABSENT', 'TARDY', 'EXCUSED']);
      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId));
      allow delete: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId));
    }

    match /sections/{sectionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId)
          && request.resource.data.teacherId == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && request.resource.data.driveUrl is string
          && request.resource.data.driveUrl.size() <= 500);
      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId)
          && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId));
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId)
          && request.resource.data.teacherId == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && request.resource.data.content is string
          && request.resource.data.content.size() <= 5000
          && createdAtValid());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId)
          && request.resource.data.teacherId == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 5000
          && request.resource.data.dueDate is string
          && validNumber(request.resource.data.maxScore, 1, 1000));
      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId)
          && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.assignmentId is string
        && request.resource.data.fileUrl is string
        && request.resource.data.fileUrl.size() <= 500;
      allow update: if isTeacher()
        || isAdmin()
        || (isStudent()
          && resource.data.studentId == request.auth.uid
          && resource.data.score == null);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /gradeReleases/{releaseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId)
          && request.resource.data.teacherId == request.auth.uid
          && request.resource.data.isReleased is bool);
      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId));
      allow delete: if isAdmin();
    }

    match /seatPlans/{seatPlanId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin()
        || (isTeacher()
          && request.resource.data.classId is string
          && classExists(request.resource.data.classId)
          && isClassTeacher(request.resource.data.classId));
      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.classId is string
          && isClassTeacher(resource.data.classId));
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.action in ['create', 'update', 'delete', 'grade', 'mark']
        && request.resource.data.collection is string
        && request.resource.data.collection.size() <= 30
        && request.resource.data.timestamp is number;
      allow delete: if isAdmin();
      allow update: if false;
    }
  }
}
